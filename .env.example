# ===========================================
# NOVAGROSS - Environment Variables
# ===========================================
# Bu dosyayı .env.local olarak kopyalayın ve değerleri doldurun

# -------------------------------------------
# SUPABASE CONFIGURATION
# -------------------------------------------
# Supabase Dashboard > Settings > API'dan alın
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -------------------------------------------
# SITE CONFIGURATION
# -------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Novagross

# -------------------------------------------
# IYZICO PAYMENT (Türkiye)
# -------------------------------------------
# iyzico Merchant Panel > Settings > API Keys
IYZICO_API_KEY=your-iyzico-api-key
IYZICO_SECRET_KEY=your-iyzico-secret-key
# Test: https://sandbox-api.iyzipay.com
# Prod: https://api.iyzipay.com
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# -------------------------------------------
# EMAIL - RESEND
# -------------------------------------------
# resend.com > API Keys
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=bildirim@novagross.com
RESEND_FROM_NAME=Novagross

# Email queue processor security (optional)
EMAIL_QUEUE_PROCESSOR_SECRET=your-strong-random-secret
EMAIL_QUEUE_MAX_RETRIES=5

# Contact email
CONTACT_EMAIL=info@novagross.com

# -------------------------------------------
# SMS - NETGSM (Opsiyonel)
# -------------------------------------------
NETGSM_USERNAME=your-netgsm-username
NETGSM_PASSWORD=your-netgsm-password
NETGSM_HEADER=NOVAGROSS

# -------------------------------------------
# CARGO - YURTICI KARGO (Opsiyonel)
# -------------------------------------------
YURTICI_API_URL=https://ws.yurticikargo.com
YURTICI_API_USER=your-username
YURTICI_API_PASS=your-password
YURTICI_CUSTOMER_CODE=your-customer-code

# -------------------------------------------
# ANALYTICS (Opsiyonel)
# -------------------------------------------
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# -------------------------------------------
# ERROR TRACKING (Opsiyonel)
# -------------------------------------------
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# -------------------------------------------
# SECURITY
# -------------------------------------------
# Webhook ve API güvenliği için rastgele bir string
REVALIDATE_SECRET=your-random-secret-string

# -------------------------------------------
# NODE ENVIRONMENT
# -------------------------------------------
NODE_ENV=development
