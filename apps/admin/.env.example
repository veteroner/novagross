# Novagross Admin - Environment Variables Template

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Site URLs
NEXT_PUBLIC_SITE_URL=https://admin.novagross.com
NEXT_PUBLIC_ADMIN_URL=https://admin.novagross.com
NEXT_PUBLIC_WEB_SITE_URL=https://novagross.com

# Resend Email Configuration
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=bildirim@novagross.com
RESEND_FROM_NAME=Novagross
RESEND_WEBHOOK_SECRET=whsec_your-webhook-secret

# Email Settings (optional)
EMAIL_RATE_LIMIT_HOURLY=10
EMAIL_RATE_LIMIT_DAILY=50
EMAIL_QUEUE_PROCESSOR_SECRET=your-processor-secret
EMAIL_QUEUE_MAX_RETRIES=5

# Contact
ADMIN_EMAIL=admin@novagross.com
CONTACT_EMAIL=info@novagross.com

# iyzico Configuration (optional - mainly for web)
IYZICO_API_KEY=your-iyzico-api-key
IYZICO_SECRET_KEY=your-iyzico-secret-key
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# 2FA (e-posta kodlu iki aşamalı doğrulama)
# Kill-switch: sorun olursa false yapıp deploy edilince 2FA devre dışı kalır
TWO_FACTOR_ENABLED=true
NEXT_PUBLIC_TWO_FACTOR_ENABLED=true
OTP_SIGNING_SECRET=generate-with-openssl-rand-hex-32
NEXT_PUBLIC_SELLER_URL=https://seller.novagross.com
