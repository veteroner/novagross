# Novagross Satıcı Paneli - Environment Variables Template

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Site URLs
NEXT_PUBLIC_SELLER_URL=https://seller.novagross.com
NEXT_PUBLIC_SITE_URL=https://novagross.com

# iyzico (reklam bakiyesi self-servis yükleme için)
IYZICO_API_KEY=your-iyzico-api-key
IYZICO_SECRET_KEY=your-iyzico-secret-key
IYZICO_BASE_URL=https://api.iyzipay.com

# Resend (2FA doğrulama kodu e-postası için)
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=bildirim@novagross.com
RESEND_FROM_NAME=Novagross

# 2FA (e-posta kodlu iki aşamalı doğrulama)
# Kill-switch: sorun olursa false yapıp deploy edilince 2FA devre dışı kalır
TWO_FACTOR_ENABLED=true
NEXT_PUBLIC_TWO_FACTOR_ENABLED=true
OTP_SIGNING_SECRET=generate-with-openssl-rand-hex-32
