{
  "name": "novagross",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "clean": "turbo clean && rm -rf node_modules",
    "dev:web": "turbo dev --filter=@novagross/web",
    "dev:admin": "turbo dev --filter=@novagross/admin",
    "dev:seller": "turbo dev --filter=@novagross/seller",
    "build:web": "turbo build --filter=@novagross/web",
    "build:admin": "turbo build --filter=@novagross/admin",
    "build:seller": "turbo build --filter=@novagross/seller",
    "db:push": "supabase db push",
    "db:generate": "supabase gen types typescript --local > packages/database/src/types.ts"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "pg": "^8.17.2",
    "turbo": "^2.3.0",
    "typescript": "^5.3.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
