{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "declaration": true,
    "declarationMap": true,
    "baseUrl": ".",
    "paths": {
      "@novagross/ui": ["./packages/ui/src"],
      "@novagross/ui/*": ["./packages/ui/src/*"],
      "@novagross/database": ["./packages/database/src"],
      "@novagross/database/*": ["./packages/database/src/*"],
      "@novagross/utils": ["./packages/utils/src"],
      "@novagross/utils/*": ["./packages/utils/src/*"]
    }
  },
  "exclude": ["node_modules"]
}
